#version 450

layout(local_size_x = 32, local_size_y = 32) in;

layout(set = 0, binding = 0) buffer OutBuffer { int C[]; };
layout(set = 0, binding = 1) buffer InBuffer  { int A[]; };
layout(set = 0, binding = 2) buffer Weight    { int B[]; };

layout(push_constant) uniform PushConstants {
    int M;
    int N;
    int K;
};

void main()
{
    int n = int(gl_GlobalInvocationID.x);
    int m = int(gl_GlobalInvocationID.y);

    if (m >= M || n >= N)
        return;

    int sum = 0;
    for (int k = 0; k < K; ++k)
        sum += A[m * K + k] * B[k * N + n];

    C[m * N + n] = sum;
}
